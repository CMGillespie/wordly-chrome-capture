{
  "manifest_version": 3,
  "name": "Wordly Capture",
  "version": "0.2.1",
  "description": "Stream browser tab audio to a Wordly translation session.",
  "permissions": [
    "tabCapture",
    "storage",
    "activeTab",
    "offscreen",
    "windows"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["config.json"],
      "matches": ["<all_urls>"]
    }
  ]
}
